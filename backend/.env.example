# XAI-Chain Backend — Environment Variables
# Copy this to backend/.env and fill in your values.

# ── Blockchain / RPC ──────────────────────────────────────────────────────────
# Get your Infura key from https://infura.io
INFURA_API_KEY=your_infura_api_key_here
INFURA_URL=https://mainnet.infura.io/v3/YOUR_INFURA_KEY
PRIVATE_KEY=your_wallet_private_key_without_0x
CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# Network-specific RPC overrides (optional — defaults to Infura URLs above)
ETHEREUM_MAINNET_RPC=https://mainnet.infura.io/v3/YOUR_INFURA_KEY
POLYGON_MAINNET_RPC=https://polygon-mainnet.infura.io/v3/YOUR_INFURA_KEY
POLYGON_AMOY_RPC=https://polygon-amoy.infura.io/v3/YOUR_INFURA_KEY

# ── Threat Intelligence (Phase 4) ─────────────────────────────────────────────
# Chainabuse community fraud reports — https://www.chainabuse.com/api
# Optional: without it, only OFAC + internal history checks run.
CHAINABUSE_API_KEY=your_chainabuse_api_key

# ── Explorer APIs ─────────────────────────────────────────────────────────────
# Etherscan (Ethereum mainnet) — https://etherscan.io/apis
# Used for: real sender_tx_count, contract_age, median gas price
ETHERSCAN_API_KEY=your_etherscan_api_key

# Polygonscan (Polygon mainnet) — https://polygonscan.com/apis
# If not set, falls back to ETHERSCAN_API_KEY for Polygon lookups
POLYGONSCAN_API_KEY=your_polygonscan_api_key

# ── IPFS / Pinata ─────────────────────────────────────────────────────────────
# Get keys from https://pinata.cloud
PINATA_API_KEY=your_pinata_api_key
PINATA_API_SECRET=your_pinata_api_secret
PINATA_JWT=your_pinata_jwt_token

# ── Database ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/xaichain

# For Docker Compose (uses service name instead of localhost)
# MONGODB_URI=mongodb://mongodb:27017/xaichain
MONGO_HOST=localhost
MONGO_PORT=27017

# ── Security ──────────────────────────────────────────────────────────────────
# Master API key — used to bootstrap client keys via POST /admin/keys.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# NEVER commit this value. Store it in your secrets manager in production.
MASTER_API_KEY=your_master_api_key_here

# Set to false ONLY for local development. Always true in production.
ENABLE_AUTH=true

# ── Cache (Redis) — Phase 3 ───────────────────────────────────────────────────
# Redis URL. Docker Compose starts Redis automatically; just use the line below.
REDIS_URL=redis://localhost:6379
# For Docker Compose: REDIS_URL=redis://redis:6379

# How long to cache a full transaction analysis result (seconds, default 5 min)
ANALYSIS_CACHE_TTL=300

# Minimum risk_score (0-100) to trigger IPFS + blockchain storage.
# Transactions below this score are saved to MongoDB only (cost saving).
STORAGE_RISK_THRESHOLD=70

# ── AWS Secrets Manager (optional, production) ────────────────────────────────
# If set, PRIVATE_KEY / MASTER_API_KEY / ETHERSCAN_API_KEY are loaded from
# AWS Secrets Manager instead of this file.
# pip install boto3  and set IAM permissions for secretsmanager:GetSecretValue
# AWS_SECRET_NAME=xai-chain/production
# AWS_REGION=us-east-1
