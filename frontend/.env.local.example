# XAI-Chain Frontend Environment Variables
# Copy to .env.local and fill in values.

# Backend API
NEXT_PUBLIC_API_URL=http://localhost:8000

# API key — must match a key created via POST /admin/keys (or MASTER_API_KEY for dev)
# Required in production; leave empty only when ENABLE_AUTH=false on the backend.
NEXT_PUBLIC_API_KEY=your_api_key_here

# Contract Configuration
NEXT_PUBLIC_CONTRACT_ADDRESS=0x_your_deployed_contract_address_here
NEXT_PUBLIC_CHAIN_ID=1

# WalletConnect Project ID (https://cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id
